APP_NAME=CONSTRUIRO
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://construiro.com

APP_LOCALE=fr
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=fr_FR

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=construiro
DB_USERNAME=
DB_PASSWORD=

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log

FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=file

# =============================================================================
# REDIS (optionnel en dev, obligatoire en production haute charge)
# =============================================================================
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_USERNAME=
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1

# En production haute charge, décommenter :
# CACHE_STORE=redis
# SESSION_DRIVER=redis
# QUEUE_CONNECTION=redis

# =============================================================================
# MAIL — SMTP
# =============================================================================
MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=465
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=ssl
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME="CONSTRUIRO ERP"

# =============================================================================
# IA — SARA (fournisseur par défaut : Groq, gratuit)
# =============================================================================
GROQ_API_KEY=

# Fournisseurs alternatifs (optionnels — configurables aussi via SuperAdmin)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_AI_API_KEY=
MISTRAL_API_KEY=

# =============================================================================
# PAIEMENT
# Les clés API des passerelles sont stockées en BDD via payment_method_configs
# et configurées depuis SuperAdmin → Méthodes de paiement.
# Les variables ci-dessous sont utilisées en fallback (dev uniquement).
# =============================================================================

# CinetPay (Côte d'Ivoire / CEMAC)
CINETPAY_API_KEY=
CINETPAY_SITE_ID=
CINETPAY_SECRET=

# Orange Money CI
ORANGE_MONEY_SANDBOX=true
ORANGE_MONEY_COUNTRY=ci
ORANGE_MONEY_MERCHANT_KEY=
ORANGE_MONEY_LOGIN=
ORANGE_MONEY_PIN=
ORANGE_MONEY_WEBHOOK_SECRET=
ORANGE_MONEY_NOTIF_URL=
ORANGE_MONEY_RETURN_URL=

# MTN Mobile Money
MTN_MOMO_ENVIRONMENT=sandbox
MTN_MOMO_SUBSCRIPTION_KEY=
MTN_MOMO_API_USER=
MTN_MOMO_API_KEY=
MTN_MOMO_CALLBACK_HOST=
MTN_MOMO_WEBHOOK_SECRET=

# Wave CI
WAVE_API_KEY=
WAVE_WEBHOOK_SECRET=

# =============================================================================
# AWS S3 (sauvegardes cloud — optionnel)
# =============================================================================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
