APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=reverb

REVERB_APP_ID=construiro-local
REVERB_APP_KEY=construiro-key
REVERB_APP_SECRET=construiro-secret
REVERB_HOST=127.0.0.1
REVERB_PORT=8080
REVERB_SCHEME=http

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

# =============================================================================
# REDIS (optionnel en dev, obligatoire en production pour performance)
# =============================================================================
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_USERNAME=
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1

# En production, changer ces 3 variables :
# CACHE_STORE=redis
# SESSION_DRIVER=redis
# QUEUE_CONNECTION=redis

# =============================================================================
# QUEUES (Worker)
# =============================================================================
# REDIS_QUEUE=construiro_jobs
# REDIS_QUEUE_RETRY_AFTER=90

# =============================================================================
# HORIZON (Laravel Horizon pour monitoring des queues — optionnel)
# =============================================================================
# HORIZON_ENABLED=true

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# SARA — Assistant IA (Groq)
GROQ_API_KEY=

# ─── Mobile Money ──────────────────────────────────────────────────────────────

# Orange Money CI (Merchant Payment API)
ORANGE_MONEY_SANDBOX=true
ORANGE_MONEY_COUNTRY=ci
ORANGE_MONEY_MERCHANT_KEY=
ORANGE_MONEY_LOGIN=
ORANGE_MONEY_PIN=
ORANGE_MONEY_WEBHOOK_SECRET=
ORANGE_MONEY_NOTIF_URL=
ORANGE_MONEY_RETURN_URL=

# MTN Mobile Money (Collections API)
MTN_MOMO_ENVIRONMENT=sandbox
MTN_MOMO_SUBSCRIPTION_KEY=
MTN_MOMO_API_USER=
MTN_MOMO_API_KEY=
MTN_MOMO_CALLBACK_HOST=
MTN_MOMO_WEBHOOK_SECRET=

# Wave CI (Checkout API)
WAVE_API_KEY=
WAVE_WEBHOOK_SECRET=
